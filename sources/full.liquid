{% if trmnl.plugin_settings.custom_fields_values.fulltype == 'typo' %}
<style>
  .xitem { font-weight: 600; overflow-wrap: anywhere;
          
          overflow-wrap: break-word; }
  .xxitem { margin-right: 0em; overflow-wrap: break-word; word-break: break-all; }
  .screen--md  .xitem { font-size: 76px; line-height: 58px;  }
  .screen--lg  .xitem { font-size: 7em; line-height: 0.76em; }
  .odd { color: #9d9c9c; }
</style>
<div id="p0t" class="text--justify xitem font p--0 m--0">
    {% for item in data %}
     <span class="xxitem font {% cycle '', 'text--gray-60' %}">{{ item.movie.title }}</span>
    {% endfor %}
    <span class="xxitem font {% cycle '', 'text--gray-60' %}">Top</span>
    <span class="xxitem font {% cycle '', 'text--gray-60' %}">Ten</span>
    <span class="xxitem font {% cycle '', 'text--gray-60' %}">TRENDING</span>
    <span class="xxitem font {% cycle '', 'text--gray-60' %}">MOVIES</span>
</div>
{% endif %}


{% if trmnl.plugin_settings.custom_fields_values.fulltype == '1x1' %}
<style>
  .sxcreen, .xview { background: black; }
  .bolder { font-weight: 600; }
  #p0t p { margin: 0; padding: 0; }
  #p0t .row { margin: 0; padding: 0; }
  .small { font-size: 13px; }
  .large { font-size: 36px; }
  .opacity { }
</style>

    {% assign total_images = 8 %}
    {% assign interval = 24 | divided_by: total_images %}
    {% assign current_hour = today | date: "%H" | plus: 0 %}
    {% assign image_index = current_hour | divided_by: interval %}

    {% assign timestamp_seconds = trmnl.system.timestamp_utc %}
    {% assign local_timestamp = timestamp_seconds | plus: trmnl.user.utc_offset %}
    {% assign two_hours_ago = local_timestamp | minus: 7200 %}
    
    {% assign row_counter = 0 %}
    {% assign last_date = "31.02." %}

    {% for item in data %}
      {% assign item_start = item.watched_at | date: "%s" | plus: 0 %}
      {% assign current_item_name = item.movie.title %}
      {% assign current_date = item.watched_at | date: "%d.%m."  | rstrip %}
	  
	  
	  {% if row_counter == image_index %}
<div id="p0t" class="layout layout--col layout--top m--0 rounded bg--black " style="xborder-radius:12px; background: url(https://{{ item.movie.images.fanart }}) no-repeat center / cover;">
      <div class="flex flex--col h--full w-full">
          <div class="item w--full">
            <div class="h--8 md:h--12 lg:h--24"><img class="image image-dither image--contain m--2" src="https://{{ item.movie.images.logo }}" style="width:100%;max-height:54px;" /></div>
            <div class="stretch"></div>
            <div class="h--8 md:h--12 lg:h--24"><img class="m--2" src="https://trakt.tv/assets/logos/logomark.square.black-a4f374d2b6b9c50d75e74c2c1cefc7e7f1b8974d25e7840baa2f491cf54cefc1.svg" height="48" /></div>
          </div>
         <div class="item stretch"></div>
          <div class="xitem w--full rounded--small p--2 bg-white opacity grid grid--cols-9">
            <div class="col col--span-1"><p class="font large">{{ image_index | plus: 1 }}</p></div>
            <div class="col col--span-8">
              <div class="row w--full flex">
                <p class="font stretch"><span class="bolder">{{ current_item_name }}</span></p>
                <p class="font small">({{ item.movie.year }})</p>
                <p class="font small">{{ item.movie.genres[0] }}</p>
              </div>
              <div class="row w--full"><p class="font"></p></div>
              <div class="row w--full"><p class="font small">{{ item.movie.tagline }}  <!-- [{{ today | date: "%H.%M" }}] --></p></div>
            </div>
          </div>    
      </div>
</div>
      {% endif %}
	  
      {% assign row_counter = row_counter | plus: 1 %}
      {% assign last_date = item.watched_at | date: "%d.%m." %}
    {% endfor %}

    
  

{% endif %}

{% if trmnl.plugin_settings.custom_fields_values.fulltype == '3x3' %}
<style>
  .screen, .view { background: black; }
</style>
<div id="p0t" class="layout layout--col layout--center m--0 bg--black">
<div class="flex w--full flex--center xbg-black gap--large pt--2 pl--4">
  <div class="bg-black xrounded p--0"><img class="" src="https://trakt.tv/assets/logos/logomark.square.black-a4f374d2b6b9c50d75e74c2c1cefc7e7f1b8974d25e7840baa2f491cf54cefc1.svg" height="48" style="vertical-align:middle;" /> </div>
  <div><span class="font bold title title--large" style="color:white;">TRENDING MOVIES  <!-- [{{ today | date: "%H.%M" }}] [{{ trmnl.plugin_settings.custom_fields_values.fulltype }}] --></span></div>
</div>
  <div class="flex flex flex--wrap w--full h--full xrounded gap--[2px] flex--content-center flex--stretch-y flex--center-x bg--black">

    {% assign timestamp_seconds = trmnl.system.timestamp_utc %}
    {% assign local_timestamp = timestamp_seconds | plus: trmnl.user.utc_offset %}
    {% assign two_hours_ago = local_timestamp | minus: 7200 %}
    
    {% assign row_counter = 0 %}
    {% assign last_date = "31.02." %}

    {% for item in data %}
      {% assign item_start = item.watched_at | date: "%s" | plus: 0 %}
      {% assign current_item_name = item.movie.title %}
      {% assign current_date = item.watched_at | date: "%d.%m."  | rstrip %}
	  
	  
	  {% if row_counter < 9 %}
      <div class="xitem w--[32cqw] rounded bg--black p--1" style="xborder-radius:12px; background: url(https://{{ item.movie.images.fanart }}) no-repeat center / cover;">
        <div class="flex flex--col h--full flex--bottom xflex--stretch-y gap--large">
        <!-- <div class="grid"> -->
          <div class="item w--full">
            <div class="h--8 md:h--12 lg:h--24 w--full"><img class="image image-dither image--contain" src="https://{{ item.movie.images.logo }}" style="width:100%;max-height:54px;" /></div>
          </div>
          <div class="item w--full">
            <div class="w--full bg-white rounded--xsmall p--1" style="text-align:center;"><span class="font bold label label--small">{{ current_item_name }} ({{ item.movie.year }})</span></div>
          </div>
          
        </div>    
      </div>
      {% endif %}
	  
      {% assign row_counter = row_counter | plus: 1 %}
      {% assign last_date = item.watched_at | date: "%d.%m." %}
    {% endfor %}

    
  </div>
  
</div>
{% endif %}

