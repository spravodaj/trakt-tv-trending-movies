<style>
  .bolder { font-weight: 600; }
  #p0t p { margin: 0; padding: 0; }
  #p0t .row { margin: 0; padding: 0; }
  .small { font-size: 13px; }
  .large { font-size: 20px; font-weight: 700; }
  .opacity { }
</style>

<div id="p0t" class="layout layout--col layout--center m--0 p--0 rounded bg--white">
  <div class="flex flex flex--wrap w--full h--full xrounded gap--[6px] flex--content-center flex--stretch-y flex--center-x bg--white">

    {% assign xtotal_images = 8 %}
    {% assign xinterval = 24 | divided_by: xtotal_images %}
    {% assign xcurrent_hour = today | date: "%H" | plus: 0 %}
    {% assign ximage_index = xcurrent_hour | divided_by: xinterval %}
    {% assign aa = xcurrent_hour | divided_by: xinterval %}
    {% assign zz = xcurrent_hour | divided_by: xinterval | plus: 2 %}

    {% assign timestamp_seconds = trmnl.system.timestamp_utc %}
    {% assign local_timestamp = timestamp_seconds | plus: trmnl.user.utc_offset %}
    {% assign two_hours_ago = local_timestamp | minus: 7200 %}
    
    {% assign row_counter = 0 %}
    {% assign last_date = "31.02." %}

    {% for item in data %}
      {% assign item_start = item.watched_at | date: "%s" | plus: 0 %}
      {% assign current_item_name = item.movie.title %}
      {% assign current_date = item.watched_at | date: "%d.%m."  | rstrip %}
	  
	  
	  {% if (row_counter >= aa) and (row_counter <= zz) %}
      <div class="xitem w--[32cqw] rounded bg--black p--2" style="xborder-radius:12px; background: url(https://{{ item.movie.images.fanart }}) no-repeat center / cover;">
      <div class="flex flex--col h--full w-full">
          <div class="item w--full">
            <div class="h--8 md:h--12 lg:h--24"><img class="image image-dither image--contain" src="https://{{ item.movie.images.logo }}" style="width:100%;max-height:54px;" /></div>
            <div class="h--8 md:h--12 lg:h--24"><img class="" src="https://trakt.tv/assets/logos/logomark.square.black-a4f374d2b6b9c50d75e74c2c1cefc7e7f1b8974d25e7840baa2f491cf54cefc1.svg" height="24" style="vertical-align:middle;" /></div>
          </div>
         <div class="item stretch"></div>
          <div class="xitem w--full rounded--xsmall p--2 bg--white opacity grid grid--cols-9">
            <div class="col col--span-1"><p class="font large">{{ row_counter | plus: 1 }}</p></div>
            <div class="col col--span-8">
                <p class="font stretch"><span class="bolder">{{ current_item_name }}</span> <!-- [{{ today | date: "%H.%M" }}] --></p>
            </div>
          </div>    
      </div>
      </div>
      {% endif %}
	  
      {% assign row_counter = row_counter | plus: 1 %}
      {% assign last_date = item.watched_at | date: "%d.%m." %}
    {% endfor %}

    
  </div>
  
</div>
